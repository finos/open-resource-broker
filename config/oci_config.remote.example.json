{
  "version": "2.0.0",
  "scheduler": {
    "type": "default"
  },
  "provider": {
    "providers": [
      {
        "name": "oci-default",
        "type": "oci",
        "enabled": true,
        "weight": 100,
        "config": {
          "region": "us-phoenix-1",
          "credential_source": "instance_principal"
        }
      }
    ],
    "selection_policy": "FIRST_AVAILABLE",
    "default_provider_type": "oci",
    "provider_defaults": {}
  },
  "storage": {
    "strategy": "json",
    "json_strategy": {
      "storage_type": "single_file",
      "base_path": "data",
      "filenames": {
        "single_file": "oci_request_database.json"
      }
    }
  },
  "logging": {
    "level": "INFO",
    "console_enabled": true
  }
}
